<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>yusp-plus-single</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>yusp-plus-single</baseDirectory>
    <fileSets>
        <fileSet>
            <directory>${basedir}/src/main/resources</directory>
            <includes>
                <include>**</include>
            </includes>
            <outputDirectory>./conf</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${basedir}/../../yusp-plus-dbinit/src/main/resources</directory>
            <includes>
                <include>dbinit.properties</include>
            </includes>
            <outputDirectory>./conf</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${basedir}/../../yusp-plus-dbinit/src/main/resources/sql</directory>
            <includes>
                <include>**/*</include>
            </includes>
            <outputDirectory>./sql</outputDirectory>
        </fileSet>

         <fileSet>
            <directory>${basedir}/target/lib</directory>
            <includes>
                <include>*.jar</include>
            </includes>
            <outputDirectory>./lib</outputDirectory>
        </fileSet>


        <fileSet>
            <directory>${basedir}/target</directory>
            <includes>
                <include>yusp-plus-single-starter.jar</include>
            </includes>
            <outputDirectory>./lib</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${basedir}/../../yusp-plus-dbinit/target</directory>
            <includes>
                <include>yusp-plus-dbinit.jar</include>
            </includes>
            <outputDirectory>./lib</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>.</directory>
            <outputDirectory>logs</outputDirectory>
            <excludes>
                <exclude>*/**</exclude>
            </excludes>
            <directoryMode>755</directoryMode>
        </fileSet>



        <fileSet>
            <directory>${basedir}/script</directory>
            <includes>
                <include>*</include>
            </includes>
            <outputDirectory>./bin</outputDirectory>
            <fileMode>755</fileMode>
        </fileSet>
    </fileSets>

</assembly>