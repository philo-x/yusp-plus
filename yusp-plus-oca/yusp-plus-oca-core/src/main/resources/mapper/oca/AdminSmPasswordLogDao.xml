<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.com.yusys.yusp.oca.dao.AdminSmPasswordLogDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="cn.com.yusys.yusp.oca.domain.entity.AdminSmPasswordLogEntity" id="adminSmPasswordLogMap">
        <result property="logId" column="LOG_ID"/>
        <result property="pwdUpTime" column="PWD_UP_TIME"/>
        <result property="pwdUped" column="PWD_UPED"/>
        <result property="updateUser" column="UPDATE_USER"/>
        <result property="userId" column="USER_ID"/>
        <result property="lastChgUsr" column="LAST_CHG_USR"/>
        <result property="lastChgDt" column="LAST_CHG_DT"/>
    </resultMap>

    <sql id="baseCloumn">
        LOG_ID, PWD_UP_TIME, PWD_UPED, UPDATE_USER, USER_ID, LAST_CHG_USR, LAST_CHG_DT
    </sql>

    <select id="getLastChangeLog" resultMap="adminSmPasswordLogMap">
        select <include refid="baseCloumn"/>
        from admin_sm_password_log
        where USER_ID = #{userId}
        order by PWD_UP_TIME desc
        limit 1
    </select>
</mapper>